{
	"schemaVersion": 1,
	"id": "chatterhat",
	"version": "${version}",
	"name": "ChatterHat",
	"description": "A talkative companion hat for Minecraft singleplayer with Ollama-powered dialogue.",
	"authors": [
		"cuspymd"
	],
	"contact": {
		"sources": "https://github.com/cuspymd/chatterhat"
	},
	"license": "CC0-1.0",
	"icon": "assets/chatterhat/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"io.github.cuspymd.chatterhat.ChatterHatMod"
		],
		"client": [
			"io.github.cuspymd.chatterhat.ChatterHatModClient"
		]
	},
	"mixins": [
		"chatterhat-mod.mixins.json",
		{
			"config": "chatterhat-mod.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}
